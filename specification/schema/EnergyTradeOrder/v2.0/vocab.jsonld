{
  "@context": {
    "@version": 1.1,
    "beckn": "https://schema.beckn.io/core/v2.0/",
    "deg": "https://schema.beckn.io/deg/EnergyTradeOrder/v2.0/",
    "schema": "https://schema.org/",
    "rdf": "http://www.w3.org/1999/02/22-rdf-syntax-ns#",
    "rdfs": "http://www.w3.org/2000/01/rdf-schema#",
    "xsd": "http://www.w3.org/2001/XMLSchema#"
  },
  "@graph": [
    {
      "@id": "deg:EnergyTradeOrder",
      "@type": "rdfs:Class",
      "rdfs:label": "Energy Trade Order",
      "rdfs:comment": "Order attributes for P2P energy trading, attached to Order.orderAttributes."
    },
    {
      "@id": "deg:EnergyTradeOrderInterUtility",
      "@type": "rdfs:Class",
      "rdfs:subClassOf": "deg:EnergyTradeOrder",
      "rdfs:label": "Energy Trade Order Inter-Utility",
      "rdfs:comment": "Extended order attributes for inter-utility (inter-discom) P2P trading."
    },
    {
      "@id": "deg:bap_id",
      "@type": "rdf:Property",
      "rdfs:label": "BAP ID",
      "rdfs:comment": "Beckn Application Platform (BAP) identifier.",
      "rdfs:domain": "deg:EnergyTradeOrder",
      "rdfs:range": "xsd:string"
    },
    {
      "@id": "deg:bpp_id",
      "@type": "rdf:Property",
      "rdfs:label": "BPP ID",
      "rdfs:comment": "Beckn Provider Platform (BPP) identifier.",
      "rdfs:domain": "deg:EnergyTradeOrder",
      "rdfs:range": "xsd:string"
    },
    {
      "@id": "deg:total_quantity",
      "@type": "rdf:Property",
      "rdfs:label": "Total quantity",
      "rdfs:comment": "Total quantity of energy in kilowatt-hours (kWh) for this trade order.",
      "rdfs:domain": "deg:EnergyTradeOrder",
      "schema:rangeIncludes": "schema:Number"
    },
    {
      "@id": "deg:utilityIdBuyer",
      "@type": "rdf:Property",
      "rdfs:label": "Utility ID Buyer",
      "rdfs:comment": "Identifier of the buyer-side utility/distribution company (discom).",
      "rdfs:domain": "deg:EnergyTradeOrderInterUtility",
      "rdfs:range": "xsd:string"
    },
    {
      "@id": "deg:utilityIdSeller",
      "@type": "rdf:Property",
      "rdfs:label": "Utility ID Seller",
      "rdfs:comment": "Identifier of the seller-side utility/distribution company (discom).",
      "rdfs:domain": "deg:EnergyTradeOrderInterUtility",
      "rdfs:range": "xsd:string"
    }
  ]
}
